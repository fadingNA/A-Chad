{
  "name": "api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:unit": "node --import tsx --test test/math.test.ts test/chunk.test.ts test/local-store.test.ts",
    "test:e2e": "node --import tsx --test test/rag-agent.e2e.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.4.0",
    "ai": "^5.0.0",
    "assistant-stream": "^0.3.19",
    "fastify": "^5.0.0",
    "ollama-ai-provider-v2": "^1.0.0",
    "pg": "^8.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "~6"
  }
}
