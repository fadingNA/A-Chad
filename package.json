{
  "name": "A-CHAD",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "concurrently --names \"app,docproc,stt\" --prefix-colors \"cyan,green,yellow\" \"turbo dev --ui=stream\" \"bash scripts/run-docproc.sh\" \"bash scripts/run-stt.sh\"",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "docproc": "bash scripts/run-docproc.sh",
    "stt": "bash scripts/run-stt.sh"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.15",
    "typescript": "~6"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
